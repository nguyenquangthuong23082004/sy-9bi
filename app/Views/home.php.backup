                            </div>
                        </div>
                    <?php endforeach; ?>
                <?php else: ?>
                    <p class="text-center text-muted">등록된 질문이 없습니다.</p>
                <?php endif; ?>
            </div>

            <div class="faq-mascot-absolute">
                <img src="<?= base_url('images/faq_graphic.png') ?>" alt="질문 아이콘" class="img-faq-graphic">
                <img src="<?= base_url('images/faq_mascot.png') ?>" alt="오토스타일 마스코트" class="img-faq-mascot">
            </div>
        </div>
    </section>
</main>

<script>
    // ══════════════════════════════════════════════════════════════════════
    // GSAP Main Visual — Zoom-Reveal Background Video Pinned Timeline
    // ══════════════════════════════════════════════════════════════════════
    (function() {
        if (typeof gsap === 'undefined') return;

        const mainWrapper = document.getElementById('main-visual-wrapper');
        const heroWhite = document.getElementById('hero-white');
        const heroDark = document.getElementById('hero-dark');
        const heroWhiteTitle = heroWhite ? heroWhite.querySelector('.hero-white-title') : null;
        const imageWrapper = heroWhite ? heroWhite.querySelector('.hero-white-image-wrapper') : null;
        const whiteOverlay = heroWhite ? heroWhite.querySelector('.hero-white-bg-overlay') : null;
        const darkTitle = heroDark ? heroDark.querySelector('.hero-dark-title') : null;
        const floatingBar = heroDark ? heroDark.querySelector('.floating-action-bar') : null;

        if (!mainWrapper || !heroWhite || !heroDark || !imageWrapper) return;

        const mm = gsap.matchMedia();

        /**
         * Setup Unified Zoom-Reveal Animation for Desktop and Mobile
         * @param {boolean} isDesktop
         */
        function initZoomReveal(isDesktop) {


            // 1. Capture initial styles dynamically from DOM (Single Source of Truth from CSS)
            const style = window.getComputedStyle(imageWrapper);
            const initialCardStyles = {
                width: style.width,
                height: style.height,
                top: style.top,
                bottom: style.bottom,
                borderRadius: style.borderRadius || '30px',
                boxShadow: style.boxShadow || 'none'
            };

            // 2. Set initial GSAP states
            gsap.set(darkTitle, {
                opacity: 0,
                y: 50,
                transition: 'none'
            });
            gsap.set(whiteOverlay, {
                opacity: 0
            });

            if (floatingBar) {
                gsap.set(floatingBar, {
                    opacity: 0,
                    y: 50,
                    xPercent: -50
                });
            }

            let visualState = "white"; // "white" or "dark"
            let transitionTimeline = null;
            let isAnimating = false;

            function playTransitionToDark() {
                if (isAnimating || visualState === "dark") return;
                isAnimating = true;
                visualState = "dark";

                if (transitionTimeline) transitionTimeline.kill();
                transitionTimeline = gsap.timeline({
                    onComplete: () => {
                        isAnimating = false;
                    }
                });

                // Fade out white title, zoom image, fade in dark overlay
                transitionTimeline.to(heroWhiteTitle, {
                    opacity: 0,
                    y: -50,
                    duration: 0.5,
                    ease: 'power2.out'
                }, 0);

                transitionTimeline.to(imageWrapper, {
                    width: '100vw',
                    height: '100vh',
                    top: '0px',
                    bottom: 'auto',
                    borderRadius: '0px',
                    boxShadow: 'none',
                    duration: 0.6,
                    ease: 'power2.out'
                }, 0);

                transitionTimeline.to(whiteOverlay, {
                    opacity: 1,
                    duration: 0.6,
                    ease: 'power2.out'
                }, 0);

                // Fade in dark contents
                transitionTimeline.to(darkTitle, {
                    opacity: 1,
                    y: 0,
                    duration: 0.5,
                    ease: 'power2.out',
                    delay: 0.1
                });

                if (floatingBar) {
                    transitionTimeline.to(floatingBar, {
                        opacity: 1,
                        y: 0,
                        duration: 0.5,
                        ease: 'power2.out'
                    }, '+=0.1');
                }
            }

            function playTransitionToWhite() {
                if (isAnimating || visualState === "white") return;
                isAnimating = true;
                visualState = "white";

                if (transitionTimeline) transitionTimeline.kill();
                transitionTimeline = gsap.timeline({
                    onComplete: () => {
                        isAnimating = false;
                    }
                });

                // Fade out dark contents simultaneously
                if (floatingBar) {
                    transitionTimeline.to(floatingBar, {
                        opacity: 0,
                        y: 50,
                        duration: 0.3,
                        ease: 'power2.in'
                    }, 0);
                }

                transitionTimeline.to(darkTitle, {
                    opacity: 0,
                    y: 50,
                    duration: 0.3,
                    ease: 'power2.in'
                }, 0);

                // Restore original visual states
                transitionTimeline.to(imageWrapper, {
                    width: initialCardStyles.width,
                    height: initialCardStyles.height,
                    top: initialCardStyles.top,
                    bottom: initialCardStyles.bottom,
                    borderRadius: initialCardStyles.borderRadius,
                    boxShadow: initialCardStyles.boxShadow,
                    duration: 0.6,
                    ease: 'power2.inOut'
                }, 0.2);

                transitionTimeline.to(whiteOverlay, {
                    opacity: 0,
                    duration: 0.6,
                    ease: 'power2.inOut'
                }, '<');

                transitionTimeline.to(heroWhiteTitle, {
                    opacity: 1,
                    y: 0,
                    duration: 0.6,
                    ease: 'power2.inOut'
                }, '<');
            }

            // Listen to mouse wheel events
            const handleWheel = (e) => {
                if (isAnimating) {
                    e.preventDefault();
                    return;
                }

                const scrollY = window.scrollY;

                if (scrollY === 0) {
                    if (e.deltaY > 0 && visualState === "white") {
                        e.preventDefault();
                        playTransitionToDark();
                    } else if (e.deltaY < 0 && visualState === "dark") {
                        e.preventDefault();
                        playTransitionToWhite();
                    }
                }
            };

            // Listen to scroll events to handle manual scrollbars or anchor links
            const handleScroll = () => {
                const scrollY = window.scrollY;
                if (scrollY > 0 && visualState === "white") {
                    visualState = "dark";
                    gsap.set(heroWhiteTitle, {
                        opacity: 0,
                        y: -50
                    });
                    gsap.set(whiteOverlay, {
                        opacity: 1
                    });
                    gsap.set(imageWrapper, {
                        width: '100vw',
                        height: '100vh',
                        top: '0px',
                        bottom: 'auto',
                        borderRadius: '0px',
                        boxShadow: 'none'
                    });
                    gsap.set(darkTitle, {
                        opacity: 1,
                        y: 0
                    });
                    if (floatingBar) gsap.set(floatingBar, {
                        opacity: 1,
                        y: 0,
                        xPercent: -50
                    });
                }
            };

            // Listen to touch events for mobile/tablet screens and laptop touchscreens
            let touchStartY = 0;
            let isTouchActive = false;

            const handleTouchStart = (e) => {
                if (window.scrollY === 0) {
                    touchStartY = e.touches[0].clientY;
                    isTouchActive = true;
                }
            };

            const handleTouchMove = (e) => {
                if (!isTouchActive) return;

                if (isAnimating) {
                    e.preventDefault();
                    return;
                }

            if (window.scrollY === 0) {
                    const touchEndY = e.touches[0].clientY;
                    const diffY = touchStartY - touchEndY;

                    if (visualState === "white") {
                        if (diffY > 5) {
                            e.preventDefault(); // Stop native browser scrolling instantly
                            if (diffY > 30) {
                                isTouchActive = false; // Disable further trigger on same swipe gesture
                                playTransitionToDark();
                            }
                        }
                    } else if (visualState === "dark") {
                        if (diffY < -5) {
                            e.preventDefault(); // Stop native browser scrolling/bouncing
                            if (diffY < -30) {
                                isTouchActive = false; // Disable further trigger on same swipe gesture
                                playTransitionToWhite();
                            }
                        }
                    }
                }
            };

            const handleTouchEnd = () => {
                isTouchActive = false;
            };

            window.addEventListener('wheel', handleWheel, {
                passive: false
            });
            window.addEventListener('scroll', handleScroll);
            window.addEventListener('touchstart', handleTouchStart, {
                passive: true
            });
            window.addEventListener('touchmove', handleTouchMove, {
                passive: false
            });
            window.addEventListener('touchend', handleTouchEnd, {
                passive: true
            });
            window.addEventListener('touchcancel', handleTouchEnd, {
                passive: true
            });

            return () => {
                if (transitionTimeline) transitionTimeline.kill();
                window.removeEventListener('wheel', handleWheel);
                window.removeEventListener('scroll', handleScroll);
                window.removeEventListener('touchstart', handleTouchStart);
                window.removeEventListener('touchmove', handleTouchMove);
                window.removeEventListener('touchend', handleTouchEnd);
                window.removeEventListener('touchcancel', handleTouchEnd);
                gsap.set([darkTitle, floatingBar, whiteOverlay, imageWrapper, heroWhiteTitle], {
                    clearProps: "all"
                });
            };
        }

        // Media Queries Registration
        mm.add("(min-width: 768px)", () => initZoomReveal(true));
        mm.add("(max-width: 767px)", () => initZoomReveal(false));

    })();

    document.addEventListener('DOMContentLoaded', function() {
        // ══════════════════════════════════════════════════════════════════════
        // GSAP Testimonials — Desktop Page-Slide Pinned ScrollTrigger
        // ══════════════════════════════════════════════════════════════════════
        (function() {
            if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

            const mm = gsap.matchMedia();

            mm.add("(min-width: 768px)", () => {
                const section = document.getElementById('testimonials');
                const cards = gsap.utils.toArray('.testimonials-section .testimonial-card');

                if (!section || cards.length === 0) return;

                // Reset any inline styles
                gsap.set(cards, {
                    clearProps: "all"
                });

                // Set up initial state of cards for desktop
                gsap.set(cards, {
                    autoAlpha: 0,
                    y: 0,
                    xPercent: -50,
                    yPercent: -50,
                    left: '50%',
                    top: '50%',
                    position: 'absolute',
                    pointerEvents: 'none'
                });

                // Card 0 starts visible and active
                gsap.set(cards[0], {
                    autoAlpha: 1,
                    y: 0,
                    pointerEvents: 'auto'
                });

                let currentIndex = 0;
                let isAnimating = false;
                let trigger;

                const getCardScrollPos = (index) => {
                    if (!trigger) return 0;
                    const start = trigger.start;
                    const pinDuration = trigger.end - trigger.start;
                    return start + (pinDuration * (index / (cards.length - 1)));
                };

                const gotoCard = (index) => {
                    if (index === currentIndex) return;
                    if (isAnimating) return;

                    // Restrict transition to exactly 1 card step at a time (prevent skipping cards)
                    const targetIndex = index > currentIndex ? currentIndex + 1 : currentIndex - 1;
                    if (targetIndex < 0 || targetIndex >= cards.length || targetIndex === currentIndex) return;

                    isAnimating = true;
                    const prevCard = cards[currentIndex];
                    const nextCard = cards[targetIndex];

                    gsap.killTweensOf(cards);

                    // Smoothly force/animate the window scroll position to the target card's offset
                    const targetScroll = getCardScrollPos(targetIndex);
                    const scrollObj = {
                        y: window.scrollY
                    };
                    gsap.to(scrollObj, {
                        y: targetScroll,
                        duration: 0.35,
                        ease: "power2.out",
                        onUpdate: () => {
                            window.scrollTo(0, scrollObj.y);
                        }
                    });

                    // Blink/flash transition
                    gsap.timeline({
                            onComplete: () => {
                                // 200ms pause rhythm cooldown before allowing the next transition
                                setTimeout(() => {
                                    isAnimating = false;
                                }, 200);
                            }
                        })
                        .to(prevCard, {
                            autoAlpha: 0,
                            pointerEvents: 'none',
                            duration: 0.12
                        })
                        .to(nextCard, {
                            autoAlpha: 1,
                            pointerEvents: 'auto',
                            duration: 0.18
                        });

                    currentIndex = targetIndex;
                };

                trigger = ScrollTrigger.create({
                    trigger: section,
                    start: 'top top',
                    end: '+=100%',
                    pin: true,
                    scrub: false,
                    onUpdate: (self) => {
                        const progress = self.progress;
                        const index = Math.round(progress * (cards.length - 1));
                        gotoCard(index);
                    },
                    snap: {
                        snapTo: 1 / (cards.length - 1),
                        duration: {
                            min: 0.15,
                            max: 0.3
                        },
                        delay: 0,
                        ease: "power2.out"
                    },
                    anticipatePin: 1
                });

                return () => {
                    // Cleanup on resize/leave desktop
                    gsap.killTweensOf(cards);
                    gsap.set(cards, {
                        clearProps: "all"
                    });
                    currentIndex = 0;
                };
            });
        })();
        // Programs Swiper
        const swiper = document.getElementById('programs-swiper');
        const dots = document.querySelectorAll('#programs-pagination .dot');

        if (swiper && dots.length > 0) {
            const updateActiveDot = () => {
                const scrollLeft = swiper.scrollLeft;
                const card = swiper.querySelector('.program-card');
                if (!card) return;

                const cardWidth = card.getBoundingClientRect().width; // exactly 1 card width (no gap)
                const index = Math.round(scrollLeft / cardWidth);

                dots.forEach((dot, idx) => {
                    if (idx === index) {
                        dot.classList.add('active');
                    } else {
                        dot.classList.remove('active');
                    }
                });
            };

            // Listen to scroll events on the swiper container
            swiper.addEventListener('scroll', updateActiveDot);

            // Add click events to dots to allow manual navigation
            dots.forEach((dot, idx) => {
                dot.addEventListener('click', () => {
                    const card = swiper.querySelector('.program-card');
                    if (!card) return;
                    const cardWidth = card.offsetWidth;
                    swiper.scrollTo({
                        left: idx * cardWidth,
                        behavior: 'smooth'
                    });
                });
            });
        }

        // Advantages Swiper
        const advSwiper = document.getElementById('advantages-swiper');
        const advDots = document.querySelectorAll('#advantages-pagination .dot');

        if (advSwiper && advDots.length > 0) {
            const updateActiveDot = () => {
                const scrollLeft = advSwiper.scrollLeft;
                const card = advSwiper.querySelector('.advantage-col');
                if (!card) return;

                const cardWidth = card.offsetWidth + 20; // card width + gap (20px)
                const index = Math.round(scrollLeft / cardWidth);

                advDots.forEach((dot, idx) => {
                    if (idx === index) {
                        dot.classList.add('active');
                    } else {
                        dot.classList.remove('active');
                    }
                });
            };

            // Listen to scroll events on the swiper container
            advSwiper.addEventListener('scroll', updateActiveDot);

            // Add click events to dots to allow manual navigation
            advDots.forEach((dot, idx) => {
                dot.addEventListener('click', () => {
                    const card = advSwiper.querySelector('.advantage-col');
                    if (!card) return;
                    const cardWidth = card.getBoundingClientRect().width + 20;
                    advSwiper.scrollTo({
                        left: idx * cardWidth,
                        behavior: 'smooth'
                    });
                });
            });
        }

        // Testimonials Swiper (Mobile only)
        const testimonialsSwiper = document.getElementById('testimonials-swiper');
        if (testimonialsSwiper) {
            const cards = testimonialsSwiper.querySelectorAll('.testimonial-card');
            const totalCards = cards.length;

            const scrollByCard = (direction) => {
                const currentScroll = testimonialsSwiper.scrollLeft;
                let currentIndex = 0;
                let minDiff = Infinity;
                cards.forEach((card, index) => {
                    const diff = Math.abs(card.offsetLeft - currentScroll);
                    if (diff < minDiff) {
                        minDiff = diff;
                        currentIndex = index;
                    }
                });

                let targetIndex = currentIndex + direction;
                if (targetIndex < 0) {
                    targetIndex = totalCards - 1;
                } else if (targetIndex >= totalCards) {
                    targetIndex = 0;
                }

                const targetOffset = cards[targetIndex].offsetLeft;
                testimonialsSwiper.scrollTo({
                    left: targetOffset,
                    behavior: 'smooth'
                });
            };

            document.querySelectorAll('.testimonials-prev').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    scrollByCard(-1);
                });
            });
            document.querySelectorAll('.testimonials-next').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    scrollByCard(1);
                });
            });
        }
    });
</script>

<?= $this->endSection() ?>