DROP TABLE IF EXISTS `tbl_bbs_comment`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `tbl_bbs_comment` (
  `tbc_idx` int(11) NOT NULL AUTO_INCREMENT,
  `code` varchar(30) NOT NULL DEFAULT '' COMMENT '게시판구분코드',
  `bbs_idx` int(11) NOT NULL DEFAULT 0 COMMENT '게시판 고유번호',
  `m_idx` int(11) NOT NULL DEFAULT 0 COMMENT '작성자 고유번호',
  `bfile1` varchar(50) NOT NULL DEFAULT '' COMMENT '업로드된파일명',
  `rfile1` varchar(50) NOT NULL DEFAULT '' COMMENT '실제파일명',
  `writer` varchar(20) NOT NULL DEFAULT '' COMMENT '작성자명',
  `comment` text NOT NULL COMMENT '내용',
  `ip_address` varchar(15) NOT NULL DEFAULT '' COMMENT '아이피',
  `r_date` datetime NOT NULL DEFAULT '0000-00-00 00:00:00' COMMENT '등록일',
  PRIMARY KEY (`tbc_idx`)
) ENGINE=MyISAM DEFAULT CHARSET=utf8mb3 COLLATE=utf8mb3_general_ci;
