INSERT INTO `tbl_bbs_list` VALUES (343,'policy',NULL,'이용약관','관리자',NULL,NULL,NULL,NULL,NULL,NULL,NULL,'<p><strong>제1조 (목적)</strong><br>이 약관은 오토스타일(이하 \"회사\"라 함)이 제공하는 서비스의 이용조건 및 절차, 회사와 회원 간의 권리, 의무 및 책임사항 등을 규정함을 목적으로 합니다. 1111</p>',NULL,0,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,1,0,0,NULL,'2026-07-14 05:24:20',2),(344,'policy',NULL,'개인정보처리방침','관리자',NULL,NULL,NULL,NULL,NULL,NULL,NULL,'<p><strong>1. 개인정보의 처리 목적</strong><br>회사는 회원가입, 세일즈 파트너 신청 및 상담 지원 등을 위해 최소한의 개인정보를 처리하고 있습니다.22222</p>',NULL,0,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,2,0,0,NULL,'2026-07-14 05:24:20',1),(24,'event',0,'현재 진행하고 있는 이벤트입니다.','관리자','','admin',0,'','','','','&lt;img title=&#39�_movie_imageM1CQJSGC.jpg&#34&#39 src=&#34/data/editor/20170304131705_movie_imageM1CQJSGC.jpg&#34&gt;&lt;br&gt;','이벤트 간략설명\n이벤트 간략설명\n이벤트 간략설명\n이벤트 간략설명',0,'','http://','2017-03-01','2017-03-03','','29.jpg','29.jpg','','','','','','','','','20170304130307.png','3.png',24,0,0,'','2015-11-11 00:00:00',0),(27,'event',0,'성형외과&뷰티센터 1주년 이벤트','관리자','','admin',0,'','','','','&lt;p&gt;333&nbsp;&lt;/p&gt;','22',2,'','http://','2017-03-06','2017-03-16','','32.jpg','32.jpg','','','','','','','','','20170304130342.png','2.png',27,0,0,'','2016-01-02 00:00:00',0),(28,'event',0,'봄봄봄 이벤트','관리자','','admin',0,'','','','','&lt;p&gt;2222&lt;/p&gt;&lt;p&gt;22&nbsp;&lt;/p&gt;','111\n222\n333\n444',11,'','http://','2017-03-04','2017-03-25','','33.jpg','33.jpg','','','','','','','','','20170304130330.png','1.png',28,0,0,'','2016-03-09 00:00:00',0),(29,'',0,'[스타인세란]당황하지 않고~끝! 유단자 조윤호님과 함께~','관리자','','admin',0,'','','','','<p><span style=\"line-height: 20.8px;\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;<span style=\"font-size:12px;\">성형외과&amp;뷰티센터 이우용센터장과 함께</span></span></p>\r\n\r\n<p>&nbsp;</p>\r\n\r\n<p style=\"text-align: center;\"><span style=\"font-size:20px;\"><strong>스타와 함께 하는 세란병원 성형외과</strong></span></p>\r\n\r\n<p style=\"text-align: center;\"><span style=\"font-size:20px;\"><strong>당황하지 않고~끝! 유단자 조윤호님과 함께~</strong></span></p>\r\n\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n\r\n<p style=\"text-align: center;\"><span style=\"font-size:14px;\">당황하지 않고,빡~ 개그맨 조윤호 님이 방문해 주셨습니다.</span></p>\r\n\r\n<p style=\"text-align: center;\"><span style=\"font-size:14px;\">조윤호님은<span style=\"line-height: 20.8px;\">&nbsp;</span><span style=\"line-height: 20.8px;\">개그콘서트의 &lt;깐죽거리 잔혹사&gt;코너에서 &lsquo;당황하지 않고 빡~끝! &rsquo;을 외치며</span></span></p>\r\n\r\n<p style=\"line-height: 20.8px; text-align: center;\"><span style=\"font-size:14px;\">허당 유단자로 큰 사랑을 받았죠!^^</span></p>\r\n\r\n<p style=\"line-height: 20.8px; text-align: center;\"><span style=\"font-size:14px;\">최근에는 다양한 예능프로는 물론 드라마에서에서 늘 밝고 긍정적인 모습으로 활약하고 있데요</span></p>\r\n\r\n<p style=\"line-height: 20.8px; text-align: center;\"><span style=\"font-size:14px;\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 앞으로 더 다양한 방송에서 더욱 밝고 행복한 모습 많이 볼 수 있길 기대합니다~~!!&nbsp;</span></p>\r\n\r\n<p style=\"line-height: 20.8px;\">&nbsp;</p>\r\n\r\n<p style=\"text-align: center;\">&nbsp;</p>\r\n\r\n<p>&nbsp;</p>\r\n\r\n<p>&nbsp;</p>\r\n','',0,'','','','','','36.jpg','36.jpg','','','','','','','','','','',29,0,0,'','2016-03-09 00:00:00',0),(46,'press',0,'원스 어폰 어 타임 인 아메리카 (Once Upon A Time In America, 1984) 원스 어폰 어 타임 인 아메리카 (Once Upon A Time In America, 1984) 원스 어폰 어 타임 인 아메리카 (Once Upon A Time In America, 1984) 원스 어폰 어 타임 인 아메리카 (Once Upon A Time In America, 1984) 원스 어폰 어 타임 인 아메리카 (Once Upon A Time In ','김형석','','admin',2,'1111','','','','<p>1921년, 좀도둑질을 일삼던 누들스는 맥스를 비롯한 친구들과 함께 <br>&nbsp;밀수품 운반 일을 하며 돈을 벌어 들인다. 누들스 무리에 위협을 느낀 벅시는 <br>&nbsp;누들스의 친구를 죽이고, 이에 분노한 누들스는 벅시를 살해한 후 감옥에 들어가게 된다. <br>&nbsp;1932년, 출소한 누들스는 어린 시절 첫사랑 데보라와 밀주 사업으로 크게 성공한 맥스를 다시 만나지만, <br>&nbsp;금주법 철폐로 그들의 밀주 사업도 위기를 맞는다. 맥스는 누들스에게 <br>&nbsp;연방준비은행을 털 것을 제안하지만 누들스는 거절한다. <br>&nbsp;1968년, 베일리 재단 파티에 초대 받은 누들스는 재단 창립 기념 사진 속에서 데보라를 발견하고 <br>&nbsp;그녀를 찾아가 자신을 초대한 베일리 장관에 대해 묻지만 그를 찾지 말라며 경고한다. <br>&nbsp;그녀의 만류에도 누들스는 마침내 의문의 베일리 장관과 마주하게 되는데...</p><p>&nbsp;</p><p>1921년, 좀도둑질을 일삼던 누들스는 맥스를 비롯한 친구들과 함께 <br>&nbsp;밀수품 운반 일을 하며 돈을 벌어 들인다. 누들스 무리에 위협을 느낀 벅시는 <br>&nbsp;누들스의 친구를 죽이고, 이에 분노한 누들스는 벅시를 살해한 후 감옥에 들어가게 된다. <br>&nbsp;1932년, 출소한 누들스는 어린 시절 첫사랑 데보라와 밀주 사업으로 크게 성공한 맥스를 다시 만나지만, <br>&nbsp;금주법 철폐로 그들의 밀주 사업도 위기를 맞는다. 맥스는 누들스에게 <br>&nbsp;연방준비은행을 털 것을 제안하지만 누들스는 거절한다. <br>&nbsp;1968년, 베일리 재단 파티에 초대 받은 누들스는 재단 창립 기념 사진 속에서 데보라를 발견하고 <br>&nbsp;그녀를 찾아가 자신을 초대한 베일리 장관에 대해 묻지만 그를 찾지 말라며 경고한다. <br>&nbsp;그녀의 만류에도 누들스는 마침내 의문의 베일리 장관과 마주하게 되는데...</p><p>&nbsp;</p><p>1921년, 좀도둑질을 일삼던 누들스는 맥스를 비롯한 친구들과 함께 <br>&nbsp;밀수품 운반 일을 하며 돈을 벌어 들인다. 누들스 무리에 위협을 느낀 벅시는 <br>&nbsp;누들스의 친구를 죽이고, 이에 분노한 누들스는 벅시를 살해한 후 감옥에 들어가게 된다. <br>&nbsp;1932년, 출소한 누들스는 어린 시절 첫사랑 데보라와 밀주 사업으로 크게 성공한 맥스를 다시 만나지만, <br>&nbsp;금주법 철폐로 그들의 밀주 사업도 위기를 맞는다. 맥스는 누들스에게 <br>&nbsp;연방준비은행을 털 것을 제안하지만 누들스는 거절한다. <br>&nbsp;1968년, 베일리 재단 파티에 초대 받은 누들스는 재단 창립 기념 사진 속에서 데보라를 발견하고 <br>&nbsp;그녀를 찾아가 자신을 초대한 베일리 장관에 대해 묻지만 그를 찾지 말라며 경고한다. <br>&nbsp;그녀의 만류에도 누들스는 마침내 의문의 베일리 장관과 마주하게 되는데...</p>','',16,'','','','','','20160822110846.jpg','11movie_image.jpg','','','','','','','','','','',46,0,0,'61.37.202.212','2016-08-22 11:21:43',0),(95,'book',0,'시즌북 테스트','관리자','','admin',0,'','','','','&lt;p&gt;&lt;img title=&#39�_2.jpg&#34&#39 src=&#34/data/editor/20161024170850_2.jpg&#34&gt;&nbsp;&lt;/p&gt;','',54,'','https://youtu.be/aFgfm6Udy1o?list=PLEb3j04KT8hUu0QzGgNcxn33zK62_a-a7','','','','','','','','','','','','','','20161024171031.png','thumb3.png',95,0,0,'61.37.202.210','2016-10-24 17:08:17