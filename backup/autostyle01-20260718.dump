--

DROP TABLE IF EXISTS `tbl_bbs_config`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `tbl_bbs_config` (
  `tbc_idx` int(11) NOT NULL AUTO_INCREMENT COMMENT '고유값',
  `board_name` varchar(50) NOT NULL DEFAULT '' COMMENT '게시판명',
  `board_code` varchar(50) NOT NULL DEFAULT '' COMMENT '게시판코드',
  `board_url` varchar(255) NOT NULL DEFAULT '' COMMENT '게시판url',
  `is_category` char(1) NOT NULL DEFAULT '' COMMENT '카테고리 사용여부',
  `is_secure` char(1) NOT NULL DEFAULT '' COMMENT '본인글보기설정',
  `is_right` char(1) NOT NULL DEFAULT '' COMMENT '작성자권한',
  `is_reply` char(1) NOT NULL DEFAULT '' COMMENT '리플여부',
  `is_comment` char(1) NOT NULL DEFAULT '' COMMENT '댓글여부',
  `is_recomm` char(1) NOT NULL DEFAULT '' COMMENT '추천여부',
  `is_notice` char(1) NOT NULL DEFAULT '' COMMENT '공지사항',
  `skin` varchar(30) NOT NULL DEFAULT '' COMMENT '스킨',
  PRIMARY KEY (`tbc_idx`)
) ENGINE=MyISAM AUTO_INCREMENT=19 DEFAULT CHARSET=utf8mb3 COLLATE=utf8mb3_general_ci;
