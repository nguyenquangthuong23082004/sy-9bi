DROP TABLE IF EXISTS `tbl_homeset`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `tbl_homeset` (
  `idx` int(11) NOT NULL,
  `site_name` varchar(255) NOT NULL COMMENT '쇼핑몰 이름 ',
  `site_name_en` varchar(255) NOT NULL,
  `domain_url` varchar(200) NOT NULL COMMENT '쇼핑몰 대표 도메인 ',
  `admin_name` varchar(200) NOT NULL COMMENT '관리자명',
  `admin_email` varchar(200) NOT NULL COMMENT '관리자 이메일 ',
  `browser_title` varchar(300) NOT NULL COMMENT 'rn브라우져 타이틀',
  `meta_tag` varchar(300) NOT NULL COMMENT '메타 테그',
  `meta_keyword` varchar(300) DEFAULT NULL COMMENT '메타 키워드',
  `home_name` varchar(255) NOT NULL COMMENT '업체명 ',
  `brand_name` varchar(255) DEFAULT NULL,
  `home_name_en` varchar(255) NOT NULL COMMENT '상호영문 ',
  `store_service01` varchar(200) NOT NULL COMMENT '업태 ',
  `store_service02` varchar(200) NOT NULL COMMENT '종목 ',
  `qna_email` varchar(200) NOT NULL COMMENT '고객문의 이메일',
  `service_item` varchar(200) NOT NULL COMMENT '서비스 품목',
  `zip` varchar(5) NOT NULL COMMENT '우편번호 ',
  `addr1` varchar(200) NOT NULL COMMENT '기본주소 ',
  `addr2` varchar(200) NOT NULL COMMENT '상세주소 ',
  `sydney_addr` varchar(200) NOT NULL COMMENT '시드니 주소',
  `comnum` varchar(255) NOT NULL COMMENT '사업자번호 ',
  `comnum_thai` varchar(255) NOT NULL,
  `tournum` varchar(100) NOT NULL COMMENT '관광사업자등록번호',
  `tournum_thai` varchar(100) NOT NULL,
  `desc_cont` text NOT NULL,
  `mallOrder` varchar(255) NOT NULL COMMENT '통신판매신고번호 ',
  `tour_no` varchar(50) NOT NULL COMMENT '관광사업등록번호',
  `com_owner` varchar(255) NOT NULL COMMENT '대표 ',
  `info_owner` varchar(255) NOT NULL COMMENT '개인정보보호 담당자명 ',
  `custom_phone` varchar(255) NOT NULL COMMENT '고객센터 번호 ',
  `fax` varchar(200) NOT NULL COMMENT '팩스번호 ',
  `sms_phone` varchar(255) NOT NULL COMMENT '문자발송 번호 ',
  `email` varchar(255) NOT NULL COMMENT '이메일 ',
  `munnote_code` varchar(255) NOT NULL COMMENT '문자노트 코',
  `logos` varchar(255) NOT NULL COMMENT '로고 ',
  `banks` varchar(200) NOT NULL COMMENT '계좌은행',
  `bank_account` varchar(20) NOT NULL COMMENT '계좌번호 ',
  `ssl_chk` varchar(1) NOT NULL DEFAULT 'N' COMMENT 'Y:사용 N:미사용 ',
  `language` varchar(20) NOT NULL COMMENT '0:한국어, 1:영어, 2:중국어,3:일본어 등 ',
  `buytext` varchar(300) NOT NULL COMMENT '구매혜택',
  `trantext` text NOT NULL COMMENT '배송안내',
  `oversea_purchase` text NOT NULL COMMENT '해외구매안내',
  `og_title` varchar(300) DEFAULT NULL,
  `og_des` varchar(300) DEFAULT NULL,
  `og_url` varchar(300) DEFAULT NULL,
  `og_site` varchar(300) DEFAULT NULL,
  `schema_jsonld` text DEFAULT NULL,
  `og_img` varchar(300) DEFAULT NULL,
  `allim_apikey` varchar(50) NOT NULL COMMENT '알림톡 apikey',
  `allim_userid` varchar(50) NOT NULL COMMENT '알림톡 userid',
  `allim_senderkey` varchar(50) NOT NULL COMMENT '알림톡 senderkey',
  `smtp_host` varchar(100) NOT NULL COMMENT '카페24메일 HOST ',
  `smtp_id` varchar(100) NOT NULL COMMENT '카페24메일 ID',
  `smtp_pass` varchar(100) NOT NULL COMMENT '카페24메일 PASS',
  `nicepay_pass` varchar(50) NOT NULL COMMENT '취소비번',
  `nicepay_mid` varchar(200) NOT NULL COMMENT '나이스페이 MID',
  `nicepay_key` varchar(200) NOT NULL COMMENT '나이스페이 Key',
  `nicepay_mid_b` varchar(200) NOT NULL COMMENT '나이스페이 빌링 MID',
  `nicepay_key_b` varchar(200) NOT NULL COMMENT '나이스페이 빌링 Key',
  `nicepay_mid_m` varchar(200) NOT NULL COMMENT '나이스페이 비인증결제 MID',
  `nicepay_key_m` varchar(200) NOT NULL COMMENT '나이스페이 비인증결제 KEY',
  `nicepay_pass_m` varchar(200) NOT NULL,
  `inicis_mid` varchar(200) NOT NULL COMMENT '이니시스 MID',
  `inicis_signkey` varchar(200) NOT NULL COMMENT '이니시스 SignKey',
  `copyright` varchar(200) NOT NULL COMMENT 'copyright',
  `mileage_min` int(10) NOT NULL COMMENT '최소사용 마일리지',
  `mileage_max` int(10) NOT NULL COMMENT '최대사용 마일리지',
  `mileage_review` int(10) NOT NULL DEFAULT 0 COMMENT '후기작성  지급마일리지',
  `mileage_cash` int(10) NOT NULL DEFAULT 0 COMMENT '현금결제 지급마일리지',
  `bank_owner` varchar(100) NOT NULL COMMENT '예금주명',
  `bank_name` varchar(100) NOT NULL COMMENT '무통장 은행명',
  `bank_no` varchar(100) NOT NULL COMMENT '무통장 계좌번호',
  `paymethod` varchar(100) NOT NULL COMMENT '결제수단',
  `us_dollar` float(10,2) NOT NULL COMMENT 'US$ 환율',
  `aud_dollar` float(10,2) NOT NULL COMMENT '호주달러',
  `baht_thai` decimal(10,4) DEFAULT NULL,
  `search_word` varchar(255) NOT NULL COMMENT '추천검색어',
  `custom_service_phone_seoul` varchar(255) DEFAULT NULL,
  `custom_service_phone_sydney` varchar(255) DEFAULT NULL,
  `custom_service_phone_sydney_call_from_australia` varchar(255) DEFAULT NULL,
  `bank_no1` varchar(100) DEFAULT NULL,
  `bank_owner_australia` varchar(100) DEFAULT NULL,
  `bank_name_australia` varchar(100) DEFAULT NULL,
  `bank_no_australia` varchar(100) DEFAULT NULL,
  `bank_no_australia1` varchar(100) DEFAULT NULL,
  `favico` varchar(255) DEFAULT NULL,
  `admin_mobile_list` varchar(255) DEFAULT NULL,
  `admin_email_list` varchar(1000) DEFAULT NULL,
  `type_extra_cost` varchar(1) DEFAULT NULL,
  `extra_cost` float DEFAULT NULL,
  `logos_footer` varchar(255) NOT NULL,
  `logos_consult` varchar(255) NOT NULL,
  `custom_service_phone_thai` varchar(255) NOT NULL,
  `custom_service_phone_thai2` varchar(255) NOT NULL,
  `hour_open` varchar(255) NOT NULL,
  `time_work` varchar(255) NOT NULL,
  `time_reservation` varchar(255) DEFAULT NULL,
  `addr_thai` varchar(255) DEFAULT NULL,
  `swift_code` varchar(255) DEFAULT NULL,
  `logo_sub_header` varchar(255) DEFAULT NULL,
  `logo_sub_footer` varchar(255) DEFAULT NULL,
  PRIMARY KEY (`idx`) USING BTREE
