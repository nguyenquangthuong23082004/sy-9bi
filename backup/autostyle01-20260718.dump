INSERT INTO `tbl_homeset` VALUES (1,'일월세미컴','ILWOL SEMICOM','https://ilwol004.mycafe24.com','ILWOL SEMICOM','info@ilwolsemi.com','오토스타일 | 장기렌터카 세일즈 파트너 모집·제휴','장기렌터카 판매를 처음 시작하는 분도 가능한 오토스타일 세일즈 파트너. 전문 영업교육, 견적·심사 지원, 투명한 수수료 정산과 개인·법인 제휴 프로그램을 확인하세요.','오토스타일, 장기렌터카, 장기렌트, 장기렌터카 판매, 장기렌터카 영업, 세일즈 파트너, 렌터카 영업사원, 장기렌트 부업, 자동차 영업, 롯데렌터카, 법인 제휴, 렌터카 제휴','일월세미컴','ILWOL SEMICOM','ILWOL SEMICOM','전자부품 유통','Turnkey Business, 개발 및 양산 지원, 품질관리','info@ilwolsemi.com','전자부품 공급, 구매대행, 재고관리, 조달관리','','서울특별시 강서구 마곡중앙6로 42 사이언스타 1024호 ','코오롱디지탈타워빌란드 309','Sydney Address','144-86-01453','1234567890','TOUR-001','TOUR-TH-001','Test Description','ORDER-001','TOURNO-001','ILWOL SEMICOM','ILWOL SEMICOM','02-2272-7678~9 / 02-2103-4070','02-2278-9047 / 02-2103-4083','02-2272-7678','admin01@auto-style.kr','MUN001','1784003880_cdfadbdb886d0fc04cd2.png','KB Bank','123456789','N','0','Buy Benefit','Delivery Info','Oversea Purchase Info','오토스타일 | 장기렌터카 세일즈 파트너 모집','수수료 공제 없는 투명한 정산과 전문 영업교육을 지원합니다. 장기렌터카 제휴 파트너와 알선 파트너로 새로운 수익을 시작해보세요.','https://auto-partner.kr/','오토스타일','{\r\n  \"@context\": \"https://schema.org\",\r\n  \"@graph\": [\r\n    {\r\n      \"@type\": \"Organization\",\r\n      \"@id\": \"https://auto-partner.kr/#organization\",\r\n      \"name\": \"오토스타일\",\r\n      \"alternateName\": \"AUTOSTYLE\",\r\n      \"url\": \"https://auto-partner.kr/\",\r\n      \"email\": \"admin01@auto-style.kr\",\r\n      \"address\": {\r\n        \"@type\": \"PostalAddress\",\r\n        \"streetAddress\": \"마곡중앙6로 42 사이언스타 1024호\",\r\n        \"addressLocality\": \"강서구\",\r\n        \"addressRegion\": \"서울특별시\",\r\n        \"addressCountry\": \"KR\"\r\n      }\r\n    },\r\n    {\r\n      \"@type\": \"WebSite\",\r\n      \"@id\": \"https://auto-partner.kr/#website\",\r\n      \"url\": \"https://auto-partner.kr/\",\r\n      \"name\": \"오토스타일\",\r\n      \"alternateName\": \"AUTOSTYLE\",\r\n      \"publisher\": {\r\n        \"@id\": \"https://auto-partner.kr/#organization\"\r\n      },\r\n      \"inLanguage\": \"ko-KR\"\r\n    },\r\n    {\r\n      \"@type\": \"WebPage\",\r\n      \"@id\": \"https://auto-partner.kr/#webpage\",\r\n      \"url\": \"https://auto-partner.kr/\",\r\n      \"name\": \"오토스타일 | 장기렌터카 세일즈 파트너 모집·제휴\",\r\n      \"description\": \"장기렌터카 판매를 처음 시작하는 분도 가능한 오토스타일 세일즈 파트너. 전문 영업교육, 견적·심사 지원, 투명한 수수료 정산과 개인·법인 제휴 프로그램을 확인하세요.\",\r\n      \"isPartOf\": {\r\n        \"@id\": \"https://auto-partner.kr/#website\"\r\n      },\r\n      \"about\": {\r\n        \"@id\": \"https://auto-partner.kr/#organization\"\r\n      },\r\n      \"inLanguage\": \"ko-KR\"\r\n    },\r\n    {\r\n      \"@type\": \"Service\",\r\n      \"@id\": \"https://auto-partner.kr/#service\",\r\n      \"name\": \"장기렌터카 세일즈 파트너 제휴\",\r\n      \"serviceType\": \"장기렌터카 판매 및 영업 제휴 지원\",\r\n      \"provider\": {\r\n        \"@id\": \"https://auto-partner.kr/#organization\"\r\n      },\r\n      \"areaServed\": {\r\n        \"@type\": \"Country\",\r\n        \"name\": \"대한민국\"\r\n      },\r\n      \"description\": \"장기렌터카 제휴 파트너와 알선 파트너를 대상으로 영업교육, 견적, 심사, 고객관리 및 수수료 정산을 지원하는 서비스입니다.\",\r\n      \"url\": \"https://auto-partner.kr/\"\r\n    }\r\n  ]\r\n}','1784008015_a5dab3bfaa1de4fbaafe.png','apikey','userid','senderkey','mw-002.cafe24.com','auto@auto-partner.kr','dhxh!@12','pass','mid','key','mid_b','key_b','mid_m','key_m','pass_m','inicis_mid','inicis_signkey','2024 AUTOSTYLE. All rights reserved.',1000,100000,0,0,'Bank Owner','Bank Name','111-222-333','card,bank',1300.00,850.00,18.0000,'전자부품, Turnkey Business, 품질관리, 글로벌 소싱',NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,'1784082689_dd0451630c8d3dc512bd.png',NULL,'pxp95211@naver.com, lifeess@naver.com,minhyung@auto-style.kr, minkyu@auto-style.kr',NULL,NULL,'1784003880_cf87ac38aaf7bc32065d.png','/consult_logo.png','070-1111-2222','070-3333-4444','09:00 ~ 18:00','Mon-Fri',NULL,NULL,NULL,NULL,NULL);
