DROP TABLE IF EXISTS `tbl_bbs_category`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `tbl_bbs_category` (
  `tbc_idx` int(11) NOT NULL AUTO_INCREMENT COMMENT '고유값',
  `subject` varchar(30) NOT NULL DEFAULT '' COMMENT '카테고리명',
  `onum` int(11) NOT NULL DEFAULT 0 COMMENT '우선순위',
  `code` varchar(30) NOT NULL DEFAULT '' COMMENT '부모게시판코드',
  PRIMARY KEY (`tbc_idx`)
) ENGINE=MyISAM AUTO_INCREMENT=9 DEFAULT CHARSET=utf8mb3 COLLATE=utf8mb3_general_ci;
/*!40101 SET character_set_client = @saved_cs_client */;

