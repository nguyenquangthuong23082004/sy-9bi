--
-- Table structure for table `tbl_bbs_list`
--

DROP TABLE IF EXISTS `tbl_bbs_list`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `tbl_bbs_list` (
  `bbs_idx` int(11) NOT NULL AUTO_INCREMENT COMMENT '고유값',
  `code` varchar(50) DEFAULT NULL,
  `category` int(11) DEFAULT NULL,
  `subject` varchar(255) DEFAULT NULL,
  `writer` varchar(30) DEFAULT NULL,
  `email` varchar(100) DEFAULT NULL,
  `user_id` varchar(20) DEFAULT NULL,
  `m_idx` int(11) DEFAULT NULL,
  `passwd` varchar(20) DEFAULT NULL,
  `notice_yn` char(1) DEFAULT NULL,
  `secure_yn` char(1) DEFAULT NULL,
  `recomm_yn` char(1) DEFAULT NULL,
  `contents` text DEFAULT NULL,
  `simple` text DEFAULT NULL,
  `hit` int(11) DEFAULT NULL,
  `country_code` varchar(2) DEFAULT NULL,
  `url` varchar(255) DEFAULT NULL,
  `s_date` varchar(10) DEFAULT NULL,
  `e_date` varchar(10) DEFAULT NULL,
  `reply` text DEFAULT NULL,
  `ufile1` varchar(255) DEFAULT NULL,
  `rfile1` varchar(255) DEFAULT NULL,
  `ufile2` varchar(255) DEFAULT NULL,
  `rfile2` varchar(255) DEFAULT NULL,
  `ufile3` varchar(255) DEFAULT NULL,
  `rfile3` varchar(255) DEFAULT NULL,
  `ufile4` varchar(255) DEFAULT NULL,
  `rfile4` varchar(255) DEFAULT NULL,
  `ufile5` varchar(255) DEFAULT NULL,
  `rfile5` varchar(255) DEFAULT NULL,
  `ufile6` varchar(255) DEFAULT NULL,
  `rfile6` varchar(255) DEFAULT NULL,
  `b_ref` int(11) DEFAULT NULL,
  `b_step` int(11) DEFAULT NULL,
  `b_level` int(11) DEFAULT NULL,
  `ip_address` varchar(15) DEFAULT NULL,
  `r_date` datetime DEFAULT NULL,
  `onum` int(11) DEFAULT NULL,
  PRIMARY KEY (`bbs_idx`)
) ENGINE=MyISAM AUTO_INCREMENT=347 DEFAULT CHARSET=utf8mb3 COLLATE=utf8mb3_general_ci;
/*!40101 SET character_set_client = @saved_cs_client */;

